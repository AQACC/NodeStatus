<resources>
    <style name="Widget.NodeStatus.SectionCard" parent="">
        <item name="cardBackgroundColor">?attr/colorSurfaceContainerHigh</item>
        <item name="cardCornerRadius">30dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">?attr/colorOutlineVariant</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.NodeStatus.ControlStrip" parent="">
        <item name="cardBackgroundColor">?attr/colorSurfaceContainerHigh</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">?attr/colorOutlineVariant</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.NodeStatus.HeroCard" parent="">
        <item name="cardBackgroundColor">@android:color/transparent</item>
        <item name="cardCornerRadius">34dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@android:color/transparent</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="Widget.NodeStatus.PrimaryButton" parent="Widget.Material3.Button">
        <item name="android:minHeight">52dp</item>
        <item name="cornerRadius">22dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.NodeStatus.OutlinedButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">52dp</item>
        <item name="cornerRadius">22dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.NodeStatus.CompactOutlinedButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">40dp</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.NodeStatus.TabButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">48dp</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.NodeStatus.Field" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">?attr/colorSurface</item>
        <item name="boxStrokeColor">?attr/colorOutlineVariant</item>
        <item name="boxCornerRadiusTopStart">20dp</item>
        <item name="boxCornerRadiusTopEnd">20dp</item>
        <item name="boxCornerRadiusBottomStart">20dp</item>
        <item name="boxCornerRadiusBottomEnd">20dp</item>
        <item name="hintTextColor">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="Widget.NodeStatus.ReadOnlyChip" parent="Widget.Material3.Chip.Assist">
        <item name="android:minHeight">32dp</item>
        <item name="chipMinHeight">32dp</item>
        <item name="chipBackgroundColor">?attr/colorSurface</item>
        <item name="chipStrokeColor">?attr/colorOutlineVariant</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipCornerRadius">16dp</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textAllCaps">false</item>
        <item name="ensureMinTouchTargetSize">false</item>
    </style>

</resources>
