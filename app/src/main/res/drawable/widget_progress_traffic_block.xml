<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <corners android:radius="22dp" />
            <gradient
                android:angle="315"
                android:endColor="#173A55"
                android:startColor="#112A3D" />
            <stroke
                android:width="1dp"
                android:color="#2D92C8" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <corners android:radius="22dp" />
                <gradient
                    android:angle="0"
                    android:endColor="#5FB9F3"
                    android:startColor="#2C6F99" />
            </shape>
        </clip>
    </item>
</layer-list>
