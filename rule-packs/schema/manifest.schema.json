{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nodestatus.local/rule-packs/schema/manifest.schema.json",
  "title": "NodeStatus Rule Pack Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "family",
    "displayName",
    "version",
    "supportedAuth",
    "capabilities",
    "fixtureDirectory"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(\\.[a-z0-9-]+)+$"
    },
    "family": {
      "type": "string"
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "supportedAuth": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "fixtureDirectory": {
      "type": "string",
      "minLength": 1
    }
  }
}
